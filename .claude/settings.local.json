{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Task",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "Bash(*)",
      "Skill(*)",
      "mcp__supabase__*",
      "mcp__*",
      "Bash(mkdir -p .claude/context/epics/.archive)",
      "Bash(cp .claude/context/epics/image-input.md .claude/context/epics/.archive/image-input.md)",
      "Bash(mkdir -p .claude/context/verify/baselines)",
      "Bash(cp .claude/context/verify/results/latest.json .claude/context/verify/baselines/image-input-baseline.json)",
      "Bash(sed -i '' 's|^github:.*|github: __TRACKED_VAR__|' .claude/epics/category-filter/epic.md)",
      "Bash(sed -i '' 's|^updated:.*|updated: __TRACKED_VAR__|' .claude/epics/category-filter/epic.md)",
      "Bash(sed -i '' 's/| 001 /| 188 /g; s/| 010 /| 189 /g; s/| 020 /| 190 /g; s/| 090 /| 191 /g' .claude/epics/category-filter/epic.md)",
      "Bash(sed -i '' 's/depends: 001/depends: 188/g; s/depends: 001, 010/depends: 188, 189/g; s/depends: all/depends: 188, 189, 190/g' .claude/epics/category-filter/epic.md)",
      "Bash(mkdir -p /Users/nguyendai/StudioProjects/wallet-ai/.claude/epics/.archived)",
      "Bash(mv /Users/nguyendai/StudioProjects/wallet-ai/.claude/epics/category-filter /Users/nguyendai/StudioProjects/wallet-ai/.claude/epics/.archived/)",
      "Bash(mv .claude/context/epics/onboarding.md .claude/context/epics/.archive/)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git checkout -- .)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(doas *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | bash *)",
      "Bash(curl * | sh *)",
      "Bash(wget * | bash *)",
      "Bash(wget * | sh *)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(> /dev/sda*)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(init *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo archive *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash-worktree-fix.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-tool-use.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-verify.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-epic-verify.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start-memory.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
