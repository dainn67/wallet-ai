{
  "verification": {
    "default_mode": "smart",
    "max_iterations": 20,
    "max_iterations_bug_fix": 15,
    "max_iterations_feature": 25,
    "max_iterations_refactor": 20,
    "custom_verify_script": null,
    "strict_task_labels": ["bug", "fix", "feature", "enhancement", "refactor"],
    "relaxed_task_labels": ["docs", "documentation", "config", "chore", "ci"],
    "skip_task_labels": ["question", "discussion", "spike"]
  },
  "context": {
    "auto_clear_between_tasks": true,
    "max_handoff_notes": 10,
    "archive_old_handoffs": true,
    "enforce_handoff_template": true,
    "warn_missing_architecture_decisions": true,
    "warn_missing_file_map_update": true
  },
  "cost_control": {
    "warn_at_iteration": 10,
    "hard_stop_at_iteration": 25,
    "model_for_verify_loops": "sonnet",
    "log_token_usage_per_task": true
  },
  "design_gate": {
    "enabled": true,
    "required_for": ["FEATURE", "REFACTOR", "ENHANCEMENT"],
    "skip_for": ["BUG_FIX", "DOCS", "CONFIG"]
  },
  "test_first": {
    "enabled": true,
    "block_on_no_tests": true,
    "warn_on_low_test_count": true
  },
  "semantic_review": {
    "enabled": true,
    "block_on_failure": false
  },
  "superpowers": {
    "auto_detect": true,
    "fallback_to_native": true
  },
  "design_phase": {
    "enabled": true,
    "auto_detect_tools": true,
    "fallback_to_text": true
  }
}
